{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graphbase-hook.js",
            "timeout": 10,
            "statusMessage": "Surfacing graph memories..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graphbase-hook.js",
            "timeout": 10,
            "statusMessage": "Checking memory freshness..."
          }
        ]
      }
    ]
  }
}
